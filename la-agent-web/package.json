{
  "name": "monorepo-demo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "docs"
  ],
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">= 20.15"
  },
  "scripts": {
    "build": "pnpm --filter ./apps/** --filter 'bmos*' build",
    "build:ai": "pnpm --filter bmos-ai-web build",
    "build:chat": "pnpm --filter bmos-chat build",
    "pre:chat": "pnpm --filter bmos-chat preview",
    "pre:ai": "pnpm --filter bmos-ai-web preview",
    "app": "pnpm --filter mobileApp start",
    "build:app": "pnpm --filter mobileApp build:apk",
    "android": "pnpm --filter mobileApp android",
    "dev": "pnpm --filter ./apps/** --filter 'bmos*' run dev",
    "dev:ai": "pnpm --filter bmos-ai-web run dev",
    "dev:chat": "pnpm --filter bmos-chat run dev",
    "i18n": "node ./scripts/i18n.js",
    "preinstall": "node -v",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "open": "pnpm --filter @bmos/open start",
    "prepare": "simple-git-hooks",
    "serve": "pnpm --filter ./apps/** run serve",
    "start": "pnpm --filter ./apps/** run start"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "axios": "^1.8.4",
    "file-saver": "^2.0.5",
    "jsonfile": "^6.1.0",
    "monaco-editor": "0.52.2",
    "qs": "^6.14.0",
    "react-native": "0.76.6",
    "vue": "3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.11.0",
    "@eslint-react/eslint-plugin": "^1.42.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "eslint": "^9.24.0",
    "eslint-plugin-format": "^1.0.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "lint-staged": "^15.5.0",
    "simple-git-hooks": "^2.12.1",
    "stylelint": "^16.18.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.5",
    "vue-eslint-parser": "^10.1.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "vite"
      ]
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
